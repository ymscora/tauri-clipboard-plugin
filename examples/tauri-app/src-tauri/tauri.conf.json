{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clipboard Pro API Tester",
  "version": "0.1.0",
  "identifier": "com.m3.clipboardpro.example",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../"
  },
  "app": {
    "windows": [
      {
        "title": "Clipboard Pro API Tester",
        "width": 1280,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
