    "@tauri-apps/api": "^2.10.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.10.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "tauri",
    "tauri-plugin",
    "clipboard",
    "clipboard-plugin",
    "clipboard-rs"
